{
  "version": 1,
  "author": "chenweidu666",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "attrs": { "cpuFrequency": "160", "flashSize": "4" }
    },
    {
      "type": "wokwi-mpu6050",
      "id": "mpu",
      "attrs": {}
    },
    {
      "type": "wokwi-led",
      "id": "led1",
      "attrs": { "color": "green" }
    },
    {
      "type": "wokwi-led",
      "id": "led2",
      "attrs": { "color": "red" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r1",
      "attrs": { "value": "470" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r2",
      "attrs": { "value": "470" }
    }
  ],
  "connections": [
    ["esp:TX", "$serialMonitor:RX", ""],
    ["esp:RX", "$serialMonitor:TX", ""],
    ["mpu:SDA", "esp:21", ""],
    ["mpu:SCL", "esp:22", ""],
    ["mpu:VCC", "esp:3V3", ""],
    ["mpu:GND", "esp:GND.1", ""],
    ["esp:17", "r1:1", ""],
    ["r1:2", "led1:A", ""],
    ["led1:C", "esp:GND.2", ""],
    ["esp:16", "r2:1", ""],
    ["r2:2", "led2:A", ""],
    ["led2:C", "esp:GND.3", ""]
  ],
  "serialMonitor": { "display": "serial" }
}
